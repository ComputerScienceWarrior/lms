<h1>Welcome to your homepage <%= @student.username %></h1>
<h2>View your created courses below!</h2>
<div id="course-functions">
    <ul>
    <% @student.courses.all.each do |students_course| %>
        <li>
            <a href="/courses/<%= students_course.title%>"><%= students_course.title %></a>
            <a href="/courses/<%= students_course.slug %>/edit"><img src="/images/edit-icon.png" width="25px" height="25px"></a>
            <form id="delete-form" action="/courses/<%= students_course.slug %>" method="POST"> 
                <input type="hidden" id="hidden" name="_method" value="DELETE">
                <input id="delete-button" style="color: red" type="submit" value="Delete Course">
            </form>

            
        </li>
    <% end %>
    </ul>
</div>

